# Local environment variables for Warrior Mindset App
# Copy this file to ".env" (or ".env.local") in this same folder and fill in
# the real values. Do NOT commit the real .env file — it is gitignored.

# --- Supabase (REQUIRED for the app to load) ---
# Found in: Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Gemini (required only for Coach Marcus AI features) ---
# Found in: Google AI Studio, or your Netlify env vars
GEMINI_API_KEY=
